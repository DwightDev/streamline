        /* ── 1. TOKENS & BASE ─────────────────────────────────────── */
.ms-feature-cluster {
  --ms-primary-950: #113058;
  --ms-primary-900: #113058;
  --ms-primary-800: #113058;
  --ms-primary-700: #113058;
  --ms-primary-600: #113058;
  --ms-primary-100: #e4eef9;
  --ms-primary-050: #f2f7fd;
  --ms-accent-700:  #ff9100;
  --ms-accent-600:  #ff9100;
  --ms-accent-500:  #ff9100;
  --ms-accent-400:  #ff9100;
  --ms-accent-100:  #fef0d8;
  --ms-accent-050:  #fff8ef;
  --ms-accent-glow: rgba(245,135,14,.22);
  --ms-sky-600:     #1d7dc0;
  --ms-sky-500:     #4aa6e8;
  --ms-sky-100:     #ddf1ff;
  --ms-sky-050:     #f0f9ff;
  --ms-success-600: #1e7a52;
  --ms-success-100: #e6f7ef;
  --ms-ink:         #101b2a;
  --ms-text:        #1e2f42;
  --ms-muted:       #54647a;
  --ms-soft:        #7a8b9e;
  --ms-line:        #dbe4ef;
  --ms-line-strong: #c4d1e2;
  --ms-surface:     #ffffff;
  --ms-surface-soft:#f6faff;
  --ms-surface-warm:#fffaf4;
  --ms-page:        #f9fbff;
  --ms-font-display:'Fraunces', Georgia, serif;
  --ms-font-body:   'DM Sans', system-ui, sans-serif;
  --ms-wrap:        1180px;
  --ms-wrap-narrow: 860px;
  --ms-gutter:      clamp(20px, 4vw, 48px);
  --ms-section-y:   clamp(72px, 9vw, 120px);
  --ms-section-y-sm:clamp(48px, 6vw, 80px);
  --ms-gap:         clamp(18px, 2.4vw, 28px);
  --ms-r-xs:   6px;
  --ms-r-sm:   12px;
  --ms-r-md:   18px;
  --ms-r-lg:   28px;
  --ms-r-pill: 999px;
  --ms-shadow-xs:    0 1px 3px rgba(9,30,60,.07);
  --ms-shadow-sm:    0 4px 16px rgba(9,30,60,.09);
  --ms-shadow-md:    0 14px 40px rgba(9,30,60,.13);
  --ms-shadow-lg:    0 24px 64px rgba(9,30,60,.17);
  --ms-shadow-focus: 0 0 0 4px rgba(74,166,232,.28);
  --ms-ease:         cubic-bezier(.25,.46,.45,.94);
  --ms-ease-spring:  cubic-bezier(.34,1.56,.64,1);
  color: var(--ms-text);
  background-color: var(--ms-page);
  font-family: var(--ms-font-body);
  font-size: 16px;
  line-height: 1.68;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}

/* ── 2. RESET ─────────────────────────────────────────────── */
.ms-feature-cluster,
.ms-feature-cluster * { box-sizing: border-box; }
.ms-feature-cluster :where(h1,h2,h3,h4,p,ul,ol,figure) { margin-top: 0; }
.ms-feature-cluster :where(img,svg) { max-width: 100%; height: auto; }
.ms-feature-cluster a {
  color: var(--ms-primary-800);
  text-underline-offset: .2em;
  transition: color .16s var(--ms-ease), background-color .16s var(--ms-ease),
              border-color .16s var(--ms-ease), box-shadow .16s var(--ms-ease),
              transform .2s var(--ms-ease-spring);
}
.ms-feature-cluster a:hover { color: var(--ms-accent-700); }
.ms-feature-cluster :where(a,button,summary):focus-visible {
  outline: none;
  box-shadow: var(--ms-shadow-focus);
  border-radius: var(--ms-r-xs);
}

/* ── 3. LAYOUT ────────────────────────────────────────────── */
.ms-feature-cluster .ms-wrap {
  width: min(var(--ms-wrap), calc(100% - var(--ms-gutter) * 2));
  margin-inline: auto;
}
.ms-feature-cluster .ms-wrap-narrow {
  width: min(var(--ms-wrap-narrow), calc(100% - var(--ms-gutter) * 2));
  margin-inline: auto;
}

/* ── 4. TYPOGRAPHY ────────────────────────────────────────── */
.ms-feature-cluster .ms-kicker {
  display: inline-flex;
  align-items: center;
  gap: .55rem;
  margin-bottom: 16px;
  color: var(--ms-accent-600);
  font-family: var(--ms-font-body);
  font-size: .73rem;
  font-weight: 600;
  letter-spacing: .11em;
  line-height: 1;
  text-transform: uppercase;
}
.ms-feature-cluster .ms-kicker::before {
  content: "";
  flex-shrink: 0;
  width: 22px;
  height: 2px;
  border-radius: 2px;
  background: var(--ms-accent-500);
}
.ms-feature-cluster h1,
.ms-feature-cluster h2,
.ms-feature-cluster h3,
.ms-feature-cluster h4 {
  font-family: var(--ms-font-display);
  font-weight: 600;
  letter-spacing: -.035em;
  color: var(--ms-primary-900);
}
.ms-feature-cluster h1 {
  max-width: 860px;
  margin-bottom: 20px;
  font-size: clamp(2.4rem, 5.5vw, 4.6rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -.05em;
}
.ms-feature-cluster h1 em {
  font-style: italic;
  color: var(--ms-accent-600);
}
.ms-feature-cluster h2 {
  max-width: 820px;
  margin-bottom: 18px;
  font-size: clamp(1.8rem, 3.8vw, 3.2rem);
  line-height: 1.05;
  letter-spacing: -.04em;
}
.ms-feature-cluster h3 {
  margin-bottom: 10px;
  font-size: clamp(1.1rem, 1.8vw, 1.6rem);
  line-height: 1.14;
  letter-spacing: -.025em;
}
.ms-feature-cluster h4 {
  margin-bottom: 8px;
  font-size: .95rem;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: -.01em;
}
.ms-feature-cluster p { margin-bottom: 1rem; }
.ms-feature-cluster .ms-section-intro {
  max-width: 760px;
  color: var(--ms-muted);
  font-size: clamp(1rem, 1.4vw, 1.16rem);
  line-height: 1.78;
}
.ms-feature-cluster .ms-lede {
  max-width: 680px;
  color: var(--ms-muted);
  font-size: clamp(1rem, 1.3vw, 1.12rem);
  line-height: 1.75;
}

/* ── 5. BREADCRUMB ────────────────────────────────────────── */
.ms-feature-cluster .ms-breadcrumb {
  padding-block: 14px;
  border-bottom: 1px solid var(--ms-line);
  background: var(--ms-surface);
}
.ms-feature-cluster .ms-breadcrumb nav {
  display: flex;
  align-items: center;
  gap: .4rem;
  font-size: .82rem;
  color: var(--ms-soft);
}
.ms-feature-cluster .ms-breadcrumb a {
  color: var(--ms-muted);
  text-decoration: none;
  font-weight: 500;
}
.ms-feature-cluster .ms-breadcrumb a:hover { color: var(--ms-primary-800); }
.ms-feature-cluster .ms-breadcrumb-sep { color: var(--ms-line-strong); }
.ms-feature-cluster .ms-breadcrumb-current {
  color: var(--ms-text);
  font-weight: 600;
}

/* ── 6. COMPACT HERO ──────────────────────────────────────── */
.ms-feature-cluster .ms-hero-compact {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  padding: clamp(56px, 8vw, 96px) 0 clamp(48px, 7vw, 80px);
  background:
    radial-gradient(ellipse 65% 80% at 88% 8%, rgba(74,166,232,.12), transparent 52%),
    radial-gradient(ellipse 45% 55% at 4% 92%, rgba(245,135,14,.08), transparent 48%),
    linear-gradient(160deg, var(--ms-primary-050) 0%, #ffffff 52%, var(--ms-surface-warm) 100%);
  border-bottom: 1px solid var(--ms-line);
}
.ms-feature-cluster .ms-hero-compact::before {
  content: "";
  position: absolute;
  top: -80px; right: -80px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74,166,232,.09) 0%, transparent 70%);
  z-index: -1;
  pointer-events: none;
}
.ms-feature-cluster .ms-hero-compact::after {
  content: "";
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  opacity: .3;
}
.ms-feature-cluster .ms-hero-compact__inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: clamp(32px, 5vw, 72px);
  align-items: center;
}
.ms-feature-cluster .ms-hero-compact__stats {
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex-shrink: 0;
}
.ms-feature-cluster .ms-hero-stat {
  padding: 16px 20px;
  border: 1px solid var(--ms-line);
  border-radius: var(--ms-r-md);
  background: rgba(255,255,255,.9);
  box-shadow: var(--ms-shadow-sm);
  text-align: center;
  min-width: 140px;
}
.ms-feature-cluster .ms-hero-stat__number {
  display: block;
  font-family: var(--ms-font-display);
  font-size: 2rem;
  font-weight: 700;
  letter-spacing: -.04em;
  line-height: 1;
  color: var(--ms-primary-900);
}
.ms-feature-cluster .ms-hero-stat__number span { color: var(--ms-accent-500); }
.ms-feature-cluster .ms-hero-stat__label {
  display: block;
  margin-top: 4px;
  font-size: .78rem;
  font-weight: 500;
  color: var(--ms-muted);
  line-height: 1.3;
}

/* ── 7. STICKY NAV ────────────────────────────────────────── */
.ms-feature-cluster .ms-nav {
  position: sticky;
  top: 0;
  z-index: 9999;
  background: rgba(255,255,255,.9);
  border-bottom: 1px solid rgba(219,228,239,.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.ms-feature-cluster .ms-nav .ms-wrap {
  display: flex;
  gap: 4px;
  overflow-x: auto;
  padding-block: 10px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.ms-feature-cluster .ms-nav .ms-wrap::-webkit-scrollbar { display: none; }
.ms-feature-cluster .ms-nav a {
  flex: 0 0 auto;
  padding: 7px 14px;
  border: 1px solid transparent;
  border-radius: var(--ms-r-pill);
  color: var(--ms-muted);
  font-size: .84rem;
  font-weight: 600;
  letter-spacing: .01em;
  text-decoration: none;
  white-space: nowrap;
  transition: color .15s, background .15s, border-color .15s;
}
.ms-feature-cluster .ms-nav a:hover,
.ms-feature-cluster .ms-nav a.active {
  color: var(--ms-primary-900);
  background: var(--ms-primary-050);
  border-color: var(--ms-line);
}
.ms-feature-cluster .ms-nav__back {
  color: var(--ms-muted) !important;
  border-color: var(--ms-line) !important;
  background: var(--ms-surface) !important;
}
.ms-feature-cluster .ms-nav__back::before { content: "← "; }
.ms-feature-cluster .ms-nav__divider {
  align-self: center;
  width: 1px;
  height: 18px;
  background: var(--ms-line);
  flex-shrink: 0;
}

/* ── 8. SECTIONS ──────────────────────────────────────────── */
.ms-feature-cluster .ms-section { padding-block: var(--ms-section-y); }
.ms-feature-cluster .ms-section-sm { padding-block: var(--ms-section-y-sm); }
.ms-feature-cluster .ms-section-light {
  background:
    radial-gradient(ellipse 70% 60% at 4% 20%, rgba(74,166,232,.09), transparent),
    linear-gradient(180deg, var(--ms-surface-soft) 0%, #fff 100%);
}
.ms-feature-cluster .ms-section-warm {
  background:
    radial-gradient(ellipse 60% 70% at 90% 15%, rgba(245,135,14,.11), transparent),
    linear-gradient(180deg, var(--ms-accent-050) 0%, #fff 100%);
}
.ms-feature-cluster .ms-section-ruled {
  border-top: 1px solid var(--ms-line);
  border-bottom: 1px solid var(--ms-line);
  background:
    radial-gradient(ellipse 55% 70% at 90% 15%, rgba(74,166,232,.07), transparent),
    linear-gradient(170deg, var(--ms-primary-050) 0%, #ffffff 60%, var(--ms-sky-050) 100%);
}

/* ── 9. GRIDS ─────────────────────────────────────────────── */
.ms-feature-cluster .ms-grid   { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: var(--ms-gap); }
.ms-feature-cluster .ms-grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: var(--ms-gap); }
.ms-feature-cluster .ms-grid-4 { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: var(--ms-gap); }
.ms-feature-cluster .ms-stack  { display: grid; gap: var(--ms-gap); }

/* ── 10. SPLIT ────────────────────────────────────────────── */
.ms-feature-cluster .ms-split {
  display: grid;
  grid-template-columns: 1fr minmax(300px, .85fr);
  gap: clamp(32px, 6vw, 80px);
  align-items: center;
}
.ms-feature-cluster .ms-split--flip { direction: rtl; }
.ms-feature-cluster .ms-split--flip > * { direction: ltr; }

/* ── 11. CARDS ────────────────────────────────────────────── */
.ms-feature-cluster .ms-card {
  position: relative;
  display: flex;
  min-height: 100%;
  flex-direction: column;
  gap: .5rem;
  padding: clamp(22px, 2.8vw, 32px);
  overflow: hidden;
  border: 1px solid var(--ms-line);
  border-radius: var(--ms-r-md);
  background: rgba(255,255,255,.9);
  box-shadow: var(--ms-shadow-xs);
  transition: transform .22s var(--ms-ease), border-color .22s var(--ms-ease),
              box-shadow .22s var(--ms-ease), background .22s var(--ms-ease);
}
.ms-feature-cluster .ms-card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  height: 3px;
  background: #4fa6e9;
  opacity: 0;
  transition: opacity .22s var(--ms-ease);
}
.ms-feature-cluster .ms-card:hover { transform: translateY(-5px); border-color: var(--ms-line-strong); background: #fff; box-shadow: var(--ms-shadow-md); }
.ms-feature-cluster .ms-card:hover::before { opacity: 1; }
.ms-feature-cluster .ms-card h3 { font-size: clamp(1.05rem, 1.4vw, 1.3rem); letter-spacing: -.02em; }
.ms-feature-cluster .ms-card p { color: var(--ms-muted); flex: 1; }
.ms-feature-cluster .ms-card a:not(.ms-btn) {
  margin-top: auto;
  padding-top: .75rem;
  color: var(--ms-primary-700);
  font-size: .875rem;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: .3rem;
}
.ms-feature-cluster .ms-card a:not(.ms-btn)::after { content: "→"; transition: transform .18s var(--ms-ease-spring); }
.ms-feature-cluster .ms-card a:not(.ms-btn):hover::after { transform: translateX(4px); }
.ms-feature-cluster .ms-card a:not(.ms-btn):hover { color: var(--ms-accent-700); }
.ms-feature-cluster .ms-card-accent {
  background: linear-gradient(160deg, #fff 60%, var(--ms-accent-050));
  border-color: rgba(245,135,14,.22);
}
.ms-feature-cluster .ms-card-sky {
  background: linear-gradient(160deg, #fff 60%, var(--ms-sky-050));
  border-color: rgba(74,166,232,.25);
}
.ms-feature-cluster .ms-card-quiet { box-shadow: none; }

/* Benefit card */
.ms-feature-cluster .ms-benefit {
  display: flex;
  flex-direction: column;
  gap: .75rem;
  padding: clamp(20px, 2.5vw, 28px);
  border: 1px solid var(--ms-line);
  border-radius: var(--ms-r-md);
  background: var(--ms-surface);
  box-shadow: var(--ms-shadow-xs);
  transition: transform .2s var(--ms-ease), box-shadow .2s var(--ms-ease), border-color .2s;
}
.ms-feature-cluster .ms-benefit:hover {
  transform: translateY(-4px);
  box-shadow: var(--ms-shadow-md);
  border-color: var(--ms-line-strong);
}
.ms-feature-cluster .ms-benefit__icon {
  width: 44px; height: 44px;
  border-radius: var(--ms-r-sm);
  background: var(--ms-accent-100);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
  transition: background .2s;
}
.ms-feature-cluster .ms-benefit:hover .ms-benefit__icon { background: var(--ms-accent-500); }
.ms-feature-cluster .ms-benefit h3 {
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: -.015em;
  margin-bottom: 0;
  line-height: 1.3;
}
.ms-feature-cluster .ms-benefit p {
  font-size: .875rem;
  color: var(--ms-muted);
  margin-bottom: 0;
  line-height: 1.6;
}

/* ── 12. FEATURE BLOCKS ───────────────────────────────────── */
.ms-feature-cluster .ms-feature-block {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(260px, .7fr);
  gap: clamp(24px, 4.5vw, 56px);
  align-items: start;
  padding-block: clamp(36px, 5.5vw, 62px);
  border-top: 1px solid var(--ms-line);
}
.ms-feature-cluster .ms-feature-block:first-of-type { border-top: 0; padding-top: 0; }
.ms-feature-cluster .ms-feature-block p { color: var(--ms-muted); }

.ms-feature-cluster .ms-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0,1fr));
  gap: 9px 22px;
  padding: 0;
  margin: 20px 0 0;
  list-style: none;
}
.ms-feature-cluster .ms-list li {
  position: relative;
  padding-left: 22px;
  color: var(--ms-text);
  font-size: .92rem;
  line-height: 1.5;
}
.ms-feature-cluster .ms-list li::before {
  content: "";
  position: absolute;
  top: .55em; left: 0;
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--ms-accent-500);
  box-shadow: 0 0 0 4px var(--ms-accent-100);
}

.ms-feature-cluster .ms-mini {
  border: 1px solid var(--ms-line);
  border-radius: var(--ms-r-md);
  background: rgba(255,255,255,.94);
  box-shadow: var(--ms-shadow-sm);
  padding: 22px;
}
.ms-feature-cluster .ms-mini h4 { color: var(--ms-primary-800); }
.ms-feature-cluster .ms-mini p { color: var(--ms-muted); font-size: .875rem; }
.ms-feature-cluster .ms-mini a {
  display: block;
  margin-top: 10px;
  color: var(--ms-primary-700);
  font-size: .875rem;
  font-weight: 600;
  text-decoration: none;
}
.ms-feature-cluster .ms-mini a::after { content: " →"; }
.ms-feature-cluster .ms-mini a:hover { color: var(--ms-accent-700); }

/* ── 13. CALLOUT / ANSWER ─────────────────────────────────── */
.ms-feature-cluster .ms-answer {
  margin: 28px 0;
  padding: clamp(20px, 3vw, 28px);
  border: 1px solid var(--ms-sky-100);
  border-left: 4px solid var(--ms-sky-500);
  border-radius: var(--ms-r-md);
  background: var(--ms-sky-050);
  box-shadow: var(--ms-shadow-xs);
}
.ms-feature-cluster .ms-answer strong { color: var(--ms-primary-900); }
.ms-feature-cluster .ms-answer p { color: var(--ms-muted); margin-bottom: 0; }

.ms-feature-cluster .ms-callout {
  padding: clamp(24px, 3.5vw, 36px);
  border: 1px solid var(--ms-accent-100);
  border-left: 4px solid var(--ms-accent-500);
  border-radius: var(--ms-r-md);
  background:
    radial-gradient(ellipse 80% 60% at 100% 0%, rgba(245,135,14,.08), transparent),
    var(--ms-accent-050);
}
.ms-feature-cluster .ms-callout h4 { color: var(--ms-primary-900); margin-bottom: 6px; }
.ms-feature-cluster .ms-callout p { color: var(--ms-muted); margin-bottom: 0; font-size: .92rem; }

/* ── 14. STAT BLOCKS ──────────────────────────────────────── */
.ms-feature-cluster .ms-stat {
  padding: 22px 24px;
  border-left: 4px solid var(--ms-accent-500);
  border-radius: var(--ms-r-sm);
  background: var(--ms-accent-050);
  border: 1px solid var(--ms-accent-100);
  border-left-width: 4px;
}
.ms-feature-cluster .ms-stat strong {
  display: block;
  font-family: var(--ms-font-display);
  font-size: clamp(1.6rem, 2.4vw, 2.4rem);
  font-weight: 700;
  letter-spacing: -.04em;
  color: var(--ms-primary-900);
  line-height: 1.1;
}
.ms-feature-cluster .ms-stat p { margin-top: 5px; margin-bottom: 0; font-size: .875rem; color: var(--ms-muted); }

/* ── 15. PROCESS STEPS ────────────────────────────────────── */
.ms-feature-cluster .ms-process {
  display: grid;
  grid-template-columns: repeat(5, minmax(0,1fr));
  gap: 10px;
