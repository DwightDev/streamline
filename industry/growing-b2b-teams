(function () {
  var root = document.querySelector('.ms-feature-cluster');
  if (!root) return;

  // Scroll reveal
  var revealObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  root.querySelectorAll('.ms-reveal').forEach(function (el) {
    var rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight && rect.bottom > 0) {
      el.classList.add('visible');
    } else {
      revealObserver.observe(el);
    }
  });

  // Active nav
  var sections = root.querySelectorAll('section[id]');
  var navLinks = root.querySelectorAll('.ms-nav a:not(.ms-nav__back)');

  var navObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function (a) { a.classList.remove('active'); });
        var active = root.querySelector('.ms-nav a[href="#' + entry.target.id + '"]');
        if (active) {
          active.classList.add('active');
          var navWrap = root.querySelector('.ms-nav .ms-wrap');
          if (navWrap) {
            navWrap.scrollLeft = active.offsetLeft - navWrap.offsetWidth / 2 + active.offsetWidth / 2;
          }
        }
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px -60% 0px' });

  sections.forEach(function (s) { navObserver.observe(s); });
})();
